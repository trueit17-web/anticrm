# Copy this file to `.env` on the server (same directory as docker-compose.prod.yml)
# and replace every CHANGE_ME value. Never commit the real .env.

# --- Database ---
POSTGRES_USER=crm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=crm

# --- Backend auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRES_IN=12h

# --- Domain (must already point to this server's IP before running init-letsencrypt.sh) ---
DOMAIN=crm.example.com

# --- First admin account, created automatically on first boot ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
SEED_ADMIN_FULLNAME=Administrator

# --- Optional: first superadmin account (manages branches, sees all of them) ---
# Only created if SEED_SUPERADMIN_USERNAME is set. Uncomment to bootstrap one.
# SEED_SUPERADMIN_USERNAME=superadmin
# SEED_SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_SUPERADMIN_PASSWORD
# SEED_SUPERADMIN_FULLNAME=Super Admin

# --- Let's Encrypt (used by deploy/init-letsencrypt.sh) ---
LETSENCRYPT_EMAIL=admin@example.com
