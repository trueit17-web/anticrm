# Copy this file to `.env` on the server (same directory as docker-compose.prod.yml)
# and replace every CHANGE_ME value. Never commit the real .env.

# --- Database ---
POSTGRES_USER=crm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=crm

# --- Backend auth ---
# Generate with: openssl rand -hex 32 (must be 32+ bytes and not a CHANGE_ME
# placeholder — the backend refuses to start in production otherwise)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRES_IN=12h

# --- Domain (must already point to this server's IP before running init-letsencrypt.sh) ---
DOMAIN=crm.example.com

# --- First admin account ---
# NOT created automatically on boot — run `npm run seed` once after first
# deploy (see DEPLOY.md). The password must be 16+ characters and not a
# CHANGE_ME placeholder, or that one-time seed run will refuse to proceed.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
SEED_ADMIN_FULLNAME=Administrator

# --- First superadmin account (manages branches, sees all of them) ---
# Also only created by that same one-time `npm run seed` run, and only if
# both of these are set to real, strong (non-placeholder, 16+ character)
# values — leave both blank to skip creating a superadmin altogether.
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_SUPERADMIN_PASSWORD
SEED_SUPERADMIN_FULLNAME=Super Admin

# --- Let's Encrypt (used by deploy/init-letsencrypt.sh) ---
LETSENCRYPT_EMAIL=admin@example.com

# --- Optional server-wide default for the "ИНН ЮЛ → название организации"
# lookup on the Прозвон call card. Free key at
# https://dadata.ru/api/find-party/ (up to 10 000 requests/month on the
# free tier). Each branch can set its own key instead on the Филиалы page
# (SUPERADMIN) — this is just the fallback when a branch hasn't.
DADATA_API_KEY=
