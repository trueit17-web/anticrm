generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MANAGER
  ADMIN
  // Sees and manages every branch; not tied to any single branchId. Only
  // role that can create branches and the first admin for each one.
  SUPERADMIN
}

// Admin-configurable dropdown lists (managed on the /admin page).
enum OptionField {
  GOV
  CB
  FSB
  CLOSER
  STATUS
  TF
}

// Workflow state of one Contact through the cold-call queue.
enum ContactStatus {
  NEW // Новый — sitting in the shared queue, unclaimed
  IN_PROGRESS // В работе — claimed by a manager, not yet actioned
  REACHED // Дозвон — converted into an Appeal
  NOT_REACHED // Недозвон
  DECLINED // Отказ
  CALLBACK // Перезвонить — stays with the same manager, doesn't return to the queue
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  // SUPERADMIN-controlled toggle (Филиалы page) for the "Прозвон" module —
  // base upload + cold-call queue. Off means every /contacts endpoint 403s
  // for this branch, not just a hidden nav icon.
  contactsEnabled Boolean @default(true)

  users         User[]
  appeals       Appeal[]
  selectOptions SelectOption[]
  userAccess    UserBranchAccess[]
  contactBatches ContactBatch[]
  contacts       Contact[]
}

// Extra branches a user can switch into beyond their home branch (User.branchId).
// Set up by SUPERADMIN for managers who work cases across multiple offices.
model UserBranchAccess {
  id       Int @id @default(autoincrement())
  userId   Int
  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

model SelectOption {
  id        Int         @id @default(autoincrement())
  branchId  Int
  branch    Branch      @relation(fields: [branchId], references: [id])
  field     OptionField
  value     String
  order     Int         @default(0)
  // Only meaningful for field=STATUS: the row-highlight color for appeals
  // with this status. Hex string, e.g. "#dcfce7".
  color     String?
  // Only meaningful for field=STATUS: the status a new trubka gets when
  // none is set explicitly. At most one true per branch+field — enforced
  // in the service layer (unset the others) rather than in the DB.
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@unique([branchId, field, value])
  @@index([branchId, field])
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  fullName     String
  passwordHash String
  role         Role     @default(USER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Set once at registration time; null only for SUPERADMIN accounts, which
  // aren't scoped to any single branch.
  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Bumped on every successful login; a JWT is only valid if its embedded
  // sessionVersion still matches. This is what makes logging in from a new
  // place invalidate any token issued before it — one active session at a
  // time per account, so a shared password stops working for the other side
  // as soon as either party logs in again.
  sessionVersion Int @default(0)

  // Employee-card fields, shown in the popup card when clicking a name in
  // a table — set by an admin from the Users page, not self-service.
  avatarUrl String?
  telegram  String?
  bio       String?

  appealsAsOperator  Appeal[]        @relation("OperatorAppeals")
  appealsAsSmsSender Appeal[]        @relation("SmsSender")
  historyEntries     AppealHistory[] @relation("HistoryChangedBy")
  branchAccess       UserBranchAccess[]
  loginEvents        LoginEvent[]
  uploadedContactBatches ContactBatch[] @relation("ContactBatchUploader")
  claimedContacts        Contact[]      @relation("ContactClaimedBy")

  @@index([branchId])
}

// One row per successful login — lets an admin see who's been accessing an
// account from where, e.g. to spot a shared password being used elsewhere.
model LoginEvent {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Appeal {
  id     Int      @id @default(autoincrement())
  date   DateTime @default(now())

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  operatorId Int
  operator   User @relation("OperatorAppeals", fields: [operatorId], references: [id])

  phone      String
  intake     Boolean @default(false)
  clientData String?
  dep        String?
  // Free-text time the client reports something happened (e.g. "около
  // 14:35") — distinct from createdAt, which is when this record itself
  // was saved. Edited manually in the edit drawer, never auto-filled.
  reportedTime String?

  // Free-form tags curated by admins on the /admin page — none of these are
  // live employee references anymore, just admin-curated option lists.
  gov    String?
  cb     String?
  fsb    String?
  closer String?
  tf     String?

  status      String  @default("Новое")
  description String?

  smsSentById Int?
  smsSentBy   User?     @relation("SmsSender", fields: [smsSentById], references: [id])
  smsSentAt   DateTime?

  history AppealHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete — kept in the DB so it can be restored from the trash view
  // instead of a hard `DELETE`. Null means active/not deleted.
  deletedAt DateTime?

  // Set when this appeal was created by converting a cold-call Contact
  // (see Contact.appealId below) rather than logged directly.
  contact Contact?

  @@index([branchId])
  @@index([operatorId])
  @@index([status])
  @@index([date])
  @@index([deletedAt])
}

model AppealHistory {
  id     Int    @id @default(autoincrement())
  appeal Appeal @relation(fields: [appealId], references: [id], onDelete: Cascade)
  appealId Int

  changedBy   User @relation("HistoryChangedBy", fields: [changedById], references: [id])
  changedById Int

  field      String
  fieldLabel String
  oldValue   String?
  newValue   String?

  changedAt DateTime @default(now())

  @@index([appealId])
}

// One uploaded client-base file — a batch of Contacts to cold-call through.
model ContactBatch {
  id           Int      @id @default(autoincrement())
  branchId     Int
  branch       Branch   @relation(fields: [branchId], references: [id])
  fileName     String
  totalCount   Int
  uploadedById Int
  uploadedBy   User     @relation("ContactBatchUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  contacts Contact[]

  @@index([branchId])
}

// One phone number from an uploaded batch, worked through the shared
// cold-call queue by managers until it either becomes an Appeal (REACHED)
// or is marked NOT_REACHED/DECLINED. CALLBACK stays claimed by the same
// manager instead of returning to the queue.
model Contact {
  id       Int    @id @default(autoincrement())
  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  batchId Int
  batch   ContactBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  phone    String
  fullName String?
  // Any other columns from the uploaded file besides phone/name, flattened
  // into a single "Label: value; Label: value" string — shown to the
  // manager as "Доп. инфа" on the call card.
  extraInfo String?

  status ContactStatus @default(NEW)

  claimedById Int?
  claimedBy   User?     @relation("ContactClaimedBy", fields: [claimedById], references: [id])
  claimedAt   DateTime?

  resultNote String?

  appealId Int?    @unique
  appeal   Appeal? @relation(fields: [appealId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status])
  @@index([batchId])
  @@index([claimedById])
}
