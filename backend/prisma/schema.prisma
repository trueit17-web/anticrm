generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MANAGER
  ADMIN
}

// Admin-configurable dropdown lists (managed on the /admin page).
enum OptionField {
  GOV
  CB
  FSB
  STATUS
  INTAKE
}

model SelectOption {
  id        Int         @id @default(autoincrement())
  field     OptionField
  value     String
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  @@unique([field, value])
  @@index([field])
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  fullName     String
  passwordHash String
  role         Role     @default(USER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appealsAsOperator  Appeal[]        @relation("OperatorAppeals")
  appealsAsCloser    Appeal[]        @relation("CloserAssignee")
  appealsAsSmsSender Appeal[]        @relation("SmsSender")
  historyEntries     AppealHistory[] @relation("HistoryChangedBy")
}

model Appeal {
  id     Int      @id @default(autoincrement())
  date   DateTime @default(now())

  operatorId Int
  operator   User @relation("OperatorAppeals", fields: [operatorId], references: [id])

  phone      String
  intake     String  @default("Телефон")
  clientData String?

  // Free-form tags curated by admins on the /admin page — no longer tied to
  // a specific employee.
  gov String?
  cb  String?
  fsb String?

  closerAssigneeId Int?
  closerAssignee   User? @relation("CloserAssignee", fields: [closerAssigneeId], references: [id])

  status      String  @default("Новое")
  description String?

  smsSentById Int?
  smsSentBy   User?     @relation("SmsSender", fields: [smsSentById], references: [id])
  smsSentAt   DateTime?

  history AppealHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorId])
  @@index([status])
  @@index([date])
}

model AppealHistory {
  id     Int    @id @default(autoincrement())
  appeal Appeal @relation(fields: [appealId], references: [id], onDelete: Cascade)
  appealId Int

  changedBy   User @relation("HistoryChangedBy", fields: [changedById], references: [id])
  changedById Int

  field      String
  fieldLabel String
  oldValue   String?
  newValue   String?

  changedAt DateTime @default(now())

  @@index([appealId])
}
