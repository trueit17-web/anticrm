DATABASE_URL="postgresql://crm:crm_password@localhost:5432/crm?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="12h"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# Used only by prisma/seed.ts to create the first admin account
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_FULLNAME="Administrator"

# Optional: only created if SEED_SUPERADMIN_USERNAME is set
# SEED_SUPERADMIN_USERNAME="superadmin"
# SEED_SUPERADMIN_PASSWORD="ChangeMe123!"
# SEED_SUPERADMIN_FULLNAME="Super Admin"

# Optional server-wide default for the "ИНН ЮЛ → название организации"
# lookup on the Прозвон call card. Free key at
# https://dadata.ru/api/find-party/ (up to 10 000 requests/month on the
# free tier). Each branch can set its own key instead on the Филиалы page
# (SUPERADMIN) — this is just the fallback when a branch hasn't. Left
# empty with no branch override either, the lookup just silently returns
# no organization name.
DADATA_API_KEY=
